// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "restore_file_from_disk": {
          "default": "confirm",
        },
        "delete_path": {
          "default": "confirm",
        },
        "terminal": {
          "default": "confirm",
        },
      },
    },
    "default_model": {
      "provider": "Z.ai",
      "model": "glm-5",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "autosave": "on_focus_change",
  "buffer_font_family": "CaskaydiaMono Nerd Font Mono",
  "buffer_font_size": 15,
  "buffer_font_fallbacks": ["D2CodingLigature Nerd Font Mono"],
  "context_servers": {
    "chrome-devtools-mcp-zed": {
      "enabled": false,
      "remote": false,
      "settings": {},
    },
    "code-index": {
      "enabled": true,
      "remote": false,
      "command": "uvx",
      "args": ["code-index-mcp"],
      "env": {},
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "",
      },
    },
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "icon_theme": "Zed (Default)",
  "inlay_hints": {
    "enabled": true,
  },
  "language_models": {
    "openai_compatible": {
      "Z.ai": {
        "api_url": "https://api.z.ai/api/coding/paas/v4",
        "available_models": [
          {
            "name": "glm-5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "minimap": {
    "max_width_columns": 42,
    "show": "always",
  },
  "relative_line_numbers": "wrapped",
  "semantic_tokens": "combined",
  "show_whitespaces": "all",
  "tabs": {
    "git_status": true,
  },
  "theme": "Ayu Dark",
  "title_bar": {
    "show_branch_icon": true,
  },
  "toolbar": {
    "code_actions": true,
  },
  "ui_font_size": 16,
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "which_key": {
    "enabled": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
}
