// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent": {
    "tool_permissions": {
      "default": "allow",
      "tools": {
        "restore_file_from_disk": {
          "default": "confirm",
        },
        "delete_path": {
          "default": "confirm",
        },
        "terminal": {
          "default": "confirm",
        },
      },
    },
    "default_model": {
      "provider": "Z.ai",
      "model": "glm-5",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_buffer_font_size": 15,
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "codex-acp": {
      "favorite_config_option_values": {
        "reasoning_effort": ["high"],
      },
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "agent_ui_font_size": 15,
  "autosave": "on_focus_change",
  "auto_install_extensions": {},
  "base_keymap": "VSCode",
  "buffer_font_family": "CaskaydiaCove Nerd Font",
  "buffer_font_size": 15,
  "buffer_font_fallbacks": ["D2CodingLigature Nerd Font"],
  "colorize_brackets": true,
  "context_servers": {
    "chrome-devtools-mcp-zed": {
      "enabled": false,
      "remote": false,
      "settings": {},
    },
    "code-index": {
      "enabled": true,
      "remote": false,
      "command": "uvx",
      "args": ["code-index-mcp"],
      "env": {},
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "",
      },
    },
  },
  "current_line_highlight": "all",
  "cursor_blink": true,
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "edit_predictions": {
    "provider": "copilot",
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
  },
  "git": {
    "inline_blame": {
      "show_commit_summary": true,
    },
  },
  "icon_theme": "Catppuccin Mocha",
  "indent_guides": {
    "enabled": true,
    "line_width": 1,
    "active_line_width": 1,
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  "inlay_hints": {
    "enabled": true,
  },
  "languages": {
    "YAML": {
      "tab_size": 2,
    },
    "JSON": {
      "tab_size": 2,
    },
  },
  "language_models": {
    "openai_compatible": {
      "Z.ai": {
        "api_url": "https://api.z.ai/api/coding/paas/v4",
        "available_models": [
          {
            "name": "glm-5",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "line_indicator_format": "long",
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "check": {
          "command": "clippy",
        },
        "cargo": {
          "allFeatures": true,
          "loadOutDirsFromCheck": true,
          "buildScripts": {
            "enable": true,
          },
        },
        "procMacro": {
          "enable": true,
          "ignored": {
            "async-trait": ["async_trait"],
            "napi-derive": ["napi"],
            "async-recursion": ["async_recursion"],
          },
        },
        "rust": {
          "analyzerTargetDir": true,
        },
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
      },
    },
  },
  "minimap": {
    "max_width_columns": 64,
    "show": "always",
  },
  "relative_line_numbers": "enabled",
  "restore_on_startup": "last_workspace",
  "semantic_tokens": "combined",
  "session": {
    "trust_all_worktrees": true,
  },
  "show_whitespaces": "all",
  "show_wrap_guides": true,
  "ssh_connections": [
    {
      "host": "vision-gamma",
      "args": [],
      "projects": [
        {
          "paths": ["/home/bob/Projects/hello_al2023/./"],
        },
      ],
    },
    {
      "host": "localhost",
      "username": "ec2-user",
      "port": 2222,
      "args": [],
      "projects": [
        {
          "paths": ["/home/ec2-user"],
        },
      ],
    },
    {
      "host": "172.28.143.150",
      "username": "ec2-user",
      "args": [],
      "projects": [
        {
          "paths": ["/home/ec2-user"],
        },
      ],
    },
    {
      "host": "172.28.143.150",
      "username": "ec2-user",
      "args": [],
      "projects": [],
    },
  ],
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "copy_on_select": true,
    "keep_selection_on_copy": true,
  },
  "theme": "Catppuccin Mocha",
  "title_bar": {
    "show_branch_icon": true,
  },
  "toolbar": {
    "code_actions": true,
  },
  "ui_font_size": 16,
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "vim_mode": true,
  "which_key": {
    "enabled": true,
    "delay_ms": 0,
  },
  "wrap_guides": [80, 120],
}
