{{- if eq .chezmoi.os "darwin" -}}
#!/bin/sh
# Brewfile 체크섬: {{ include (joinPath .chezmoi.workingTree "Brewfile") | sha256sum }}
set -eu

brewfile="{{ joinPath .chezmoi.workingTree "Brewfile" }}"

if ! command -v brew >/dev/null 2>&1; then
  printf '오류: Homebrew를 찾을 수 없습니다. Homebrew를 수동으로 설치한 뒤 다시 실행하세요.\n' >&2
  exit 1
fi

brew bundle --file="$brewfile" --no-upgrade
{{- end -}}
