{{- if ne .chezmoi.os "windows" -}}
#!/bin/sh
set -eu

source_file="$HOME/.claude/CLAUDE.md"
target_directory="$HOME/.codex"
target_file="$target_directory/AGENTS.md"
cache_directory={{ .chezmoi.cacheDir | quote }}
cache_file={{ joinPath .chezmoi.cacheDir "agent-instructions.last" | quote }}
temporary_file=
cache_temporary_file=

cleanup() {
  [ -z "$temporary_file" ] || rm -f "$temporary_file"
  [ -z "$cache_temporary_file" ] || rm -f "$cache_temporary_file"
}

trap cleanup EXIT HUP INT TERM

if [ ! -f "$source_file" ]; then
  printf '오류: 하드링크 원본 지침 파일이 없습니다: %s\n' "$source_file" >&2
  exit 1
fi

mkdir -p "$target_directory"

link_required=1
if [ -e "$target_file" ] || [ -L "$target_file" ]; then
  if test "$source_file" -ef "$target_file"; then
    link_required=0
  fi

  if [ "$link_required" -eq 1 ] && ! cmp -s "$source_file" "$target_file"; then
    printf '오류: 기존 ~/.codex/AGENTS.md의 내용이 원본 지침과 다릅니다.\n' >&2
    exit 1
  fi
fi

if [ "$link_required" -eq 1 ]; then
  temporary_file=$(mktemp "$target_directory/.AGENTS.md.XXXXXX")
  rm "$temporary_file"

  if ! ln "$source_file" "$temporary_file"; then
    printf '오류: 임시 Codex 지침 하드링크를 만들 수 없습니다.\n' >&2
    exit 1
  fi

  if ! mv -f "$temporary_file" "$target_file"; then
    printf '오류: Codex 지침 하드링크를 원자적으로 교체할 수 없습니다.\n' >&2
    exit 1
  fi
  temporary_file=
fi

umask 077
mkdir -p "$cache_directory"
cache_temporary_file=$(mktemp "$cache_directory/.agent-instructions.last.XXXXXX")
cp "$source_file" "$cache_temporary_file"
mv -f "$cache_temporary_file" "$cache_file"
cache_temporary_file=
{{- end -}}
