{{- if ne .chezmoi.os "windows" -}}
#!/bin/sh
set -eu

for command_name in git curl tar; do
  if ! command -v "$command_name" >/dev/null 2>&1; then
    printf '오류: 부트스트랩에 필요한 명령을 찾을 수 없습니다: %s\n' "$command_name" >&2
    exit 1
  fi
done

clone_if_missing() {
  repository=$1
  destination=$2

  if [ ! -e "$destination" ]; then
    mkdir -p "$(dirname "$destination")"
    git clone --depth=1 "$repository" "$destination"
  fi
}

clone_if_missing https://github.com/ohmyzsh/ohmyzsh.git "$HOME/.oh-my-zsh"
clone_if_missing https://github.com/spaceship-prompt/spaceship-prompt.git "$HOME/.oh-my-zsh/custom/themes/spaceship-prompt"
clone_if_missing https://github.com/gpakosz/.tmux.git "$HOME/.tmux"
clone_if_missing https://github.com/LazyVim/starter.git "$HOME/.config/nvim"

{{- if eq .chezmoi.os "linux" }}
nvim_directory="nvim-linux-{{ if eq .chezmoi.arch "amd64" }}x86_64{{ else if eq .chezmoi.arch "arm64" }}arm64{{ else }}unsupported{{ end }}"
nvim_destination="$HOME/.local/opt/$nvim_directory"

has_supported_nvim() {
{{ if or (eq .chezmoi.arch "amd64") (eq .chezmoi.arch "arm64") }}
  if [ -x "$nvim_destination/bin/nvim" ]; then
    return 0
  fi
{{ end }}
  if ! command -v nvim >/dev/null 2>&1; then
    return 1
  fi

  version=$(nvim --version | sed -n '1s/^NVIM v//p')
  case "$version" in
    *.*.*) ;;
    *) return 1 ;;
  esac

  major=${version%%.*}
  version=${version#*.}
  minor=${version%%.*}
  patch=${version#*.}
  patch=${patch%%[^0-9]*}

  [ "$major" -gt 0 ] ||
    { [ "$minor" -gt 8 ] || { [ "$minor" -eq 8 ] && [ "$patch" -ge 1 ]; }; }
}

if ! has_supported_nvim; then
{{- if and (ne .chezmoi.arch "amd64") (ne .chezmoi.arch "arm64") }}
  printf '오류: 지원하지 않는 Linux CPU 아키텍처입니다: {{ .chezmoi.arch }}\n' >&2
  exit 1
{{- else }}
  if [ -e "$nvim_destination" ]; then
    printf '오류: 기존 로컬 Neovim 설치를 덮어쓸 수 없습니다: %s\n' "$nvim_destination" >&2
    exit 1
  fi

  temporary_directory=$(mktemp -d)
  trap 'rm -rf "$temporary_directory"' EXIT HUP INT TERM
  curl -fL --output "$temporary_directory/$nvim_directory.tar.gz" \
    "https://github.com/neovim/neovim/releases/latest/download/$nvim_directory.tar.gz"
  tar -xzf "$temporary_directory/$nvim_directory.tar.gz" -C "$temporary_directory"
  mkdir -p "$HOME/.local/opt"
  mv "$temporary_directory/$nvim_directory" "$nvim_destination"
{{- end }}
fi
{{- end }}
{{- end -}}
