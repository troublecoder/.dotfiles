{{- if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = 'Stop'

if (-not (Get-Command mise -ErrorAction SilentlyContinue)) {
    if (-not (Get-Command winget -ErrorAction SilentlyContinue)) {
        throw "오류: mise 설치에 필요한 winget을 찾을 수 없습니다."
    }

    winget install --id jdx.mise --exact --accept-package-agreements --accept-source-agreements --silent
    if ($LASTEXITCODE -ne 0) {
        throw "오류: winget으로 mise를 설치하지 못했습니다. 종료 코드: $LASTEXITCODE"
    }
}
{{- end -}}
